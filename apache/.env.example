# ─── Data directory ───────────────────────────────────────────────────────────
# All Apache and MySQL files will be stored here.
# Override on the command line: APACHE_DATA_DIR=/mnt/storage docker compose up -d
APACHE_DATA_DIR=/srv/www.docker

# ─── Ports ────────────────────────────────────────────────────────────────────
# Note: Nextcloud uses 8080 by default – use different ports if both stacks run together
APACHE_HTTP_PORT=8081
APACHE_HTTPS_PORT=8444

# ─── Apache ───────────────────────────────────────────────────────────────────
APACHE_SERVER_NAME=localhost

# ─── MySQL ────────────────────────────────────────────────────────────────────
# MYSQL_DATABASE is the database created automatically on first container start.
# migrate-native-to-docker.sh creates additional databases (wordpress, wordpress_mxtracks)
# directly via root after the container is up – no extra env vars needed for those.
MYSQL_DATABASE=webapp
MYSQL_USER=webapp
MYSQL_PASSWORD=changeme_db
MYSQL_ROOT_PASSWORD=changeme_root

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_DIR=./backups

# ─── Migration (migrate-native-to-docker.sh) ─────────────────────────────────
# Paths on the SOURCE (native) server – only needed during migration, not at runtime.
# NATIVE_VHOSTS_DIR=/srv/www/vhosts     # parent of dev.mxtracks and mxdocs

