# ─── Data directory ───────────────────────────────────────────────────────────
# All Apache and MySQL files will be stored here.
# Override on the command line: APACHE_DATA_DIR=/mnt/storage docker compose up -d
APACHE_DATA_DIR=/srv/www.docker

# ─── Ports ────────────────────────────────────────────────────────────────────
# Note: Nextcloud uses 8080 by default – use different ports if both stacks run together
APACHE_HTTP_PORT=8081
APACHE_HTTPS_PORT=8444

# ─── Apache ───────────────────────────────────────────────────────────────────
APACHE_SERVER_NAME=localhost

# ─── MySQL ────────────────────────────────────────────────────────────────────
# MYSQL_DATABASE is the database created automatically on first container start.
# migrate-native-to-docker.sh creates additional databases (wordpress, wordpress_mxtracks)
# directly via root after the container is up – no extra env vars needed for those.
MYSQL_DATABASE=webapp
MYSQL_USER=webapp
MYSQL_PASSWORD=changeme_db
MYSQL_ROOT_PASSWORD=changeme_root

# ─── Backup ───────────────────────────────────────────────────────────────────
BACKUP_DIR=./backups

# ─── Migration (migrate-native-to-docker.sh) ─────────────────────────────────
# Paths on the SOURCE (native) server – only needed during migration, not at runtime.
# NATIVE_VHOSTS_DIR=/srv/www/vhosts     # parent of dev.mxtracks and mxdocs

# ─── Mirror sync (sync-to-mirror.sh) ─────────────────────────────────────────
# Script is run on the source server (latitude); it SSHes into the mirror (mac2016).
# The three MIRROR_ vars marked with (*) must match the mirror's own .env values:
MIRROR_HOST=mac2016                              # SSH hostname of the mirror
MIRROR_USER=hannes                               # SSH user on the mirror
MIRROR_SSH_PORT=22
MIRROR_APACHE_DIR=/Users/hannes/git/dockerApache/apache   # docker compose dir on mirror (absolute path – ~ expands to source machine's home, not mirror's)
MIRROR_DATA_DIR=/Volumes/SamsungT1/apache                  # (*) must equal mirror's APACHE_DATA_DIR (absolute path)
MIRROR_MYSQL_ROOT_PASSWORD=changeme_root         # (*) must equal mirror's MYSQL_ROOT_PASSWORD
MIRROR_HTTP_PORT=8080                            # (*) must equal mirror's APACHE_HTTP_PORT
MIRROR_EXTRA_PATH=/usr/local/bin                 # prepended to PATH on mirror (Docker Desktop on macOS)
MIRROR_SHELL=zsh                                 # login shell on mirror (zsh for macOS, bash for Linux)                              # login shell on mirror (zsh for macOS, bash for Linux)

