# ─── Data directory ──────────────────────────────────────────────────────────
# All Nextcloud and PostgreSQL files will be stored under this path.
# Override on the command line:  NEXTCLOUD_DATA_DIR=/mnt/storage docker compose up -d
NEXTCLOUD_DATA_DIR=./data

# ─── Backup directory ────────────────────────────────────────────────────────
# Target folder for backup.sh (timestamped sub-folders will be created here)
BACKUP_DIR=./backups

# ─── Architecture ────────────────────────────────────────────────────────────
# Set to arm64 on Apple Silicon / Raspberry Pi, amd64 on Intel/AMD
# Docker will auto-detect in most cases; override if needed.
ARCH=amd64
# ARCH=arm64

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=changeme_db

# ─── Nextcloud ───────────────────────────────────────────────────────────────
NEXTCLOUD_PORT=8082
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme_admin

# NEXTCLOUD_TRUSTED_DOMAINS – space-separated list of hostnames/IPs that Nextcloud
# will accept in the HTTP Host header. Any request arriving with a Host that is NOT
# in this list is rejected with "Access through untrusted domain".
#
# Rules:
#   • Always include every hostname or IP you use to reach Nextcloud.
#   • Use the bare hostname/IP – no http://, no port number.
#   • Multiple values must be space-separated and the whole value quoted.
#   • Wildcards are NOT supported – list each name explicitly.
#
# Common examples:
#   localhost                  → local browser on the same machine
#   192.168.1.100              → LAN access by IP
#   cloud.example.com          → public domain name
#   nextcloud.myserver.local   → internal DNS name
#
# After changing this value you must restart the stack:
#   docker compose down && docker compose up -d
#
NEXTCLOUD_TRUSTED_DOMAINS="localhost 192.168.1.100 cloud.example.com"

# PHP limits
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_LIMIT=10G

